<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Electrical Godown Inventory</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;font-size:14px;background:#f4f6fa;color:#1a1a1a;min-height:100vh}
.topbar{background:#185FA5;color:#fff;padding:12px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.topbar .title{font-size:17px;font-weight:600}
.topbar .sub{font-size:12px;opacity:.8}
.sync{font-size:11px;background:rgba(255,255,255,.18);padding:4px 10px;border-radius:20px}
.nav{display:flex;gap:0;background:#fff;border-bottom:1px solid #e0e0e0;overflow-x:auto}
.nav button{padding:12px 16px;border:none;background:transparent;color:#555;cursor:pointer;font-size:13px;font-family:inherit;white-space:nowrap;border-bottom:3px solid transparent}
.nav button.active{color:#185FA5;border-bottom:3px solid #185FA5;font-weight:600}
.nav .abadge{display:inline-block;background:#e53935;color:#fff;border-radius:10px;font-size:10px;padding:1px 6px;margin-left:4px}
.con{max-width:960px;margin:0 auto;padding:16px}
.page{display:none}.page.active{display:block}
.card{background:#fff;border-radius:10px;border:1px solid #e8e8e8;padding:18px;margin-bottom:14px}
.card-title{font-size:15px;font-weight:600;margin-bottom:14px}
.grid2{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:16px}
.metric{background:#f0f4fa;border-radius:8px;padding:14px;text-align:center}
.metric .ml{font-size:11px;color:#666;margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px}
.metric .mv{font-size:26px;font-weight:700}
.mv.danger{color:#c62828}.mv.success{color:#2e7d32}.mv.info{color:#185FA5}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;padding:9px 10px;background:#f8f9fa;border-bottom:1px solid #e0e0e0;color:#555;font-weight:500;font-size:12px}
td{padding:9px 10px;border-bottom:1px solid #f0f0f0;vertical-align:middle}
tr:last-child td{border-bottom:none}
.badge{display:inline-block;padding:3px 9px;border-radius:12px;font-size:11px;font-weight:600}
.badge.low{background:#ffebee;color:#c62828}
.badge.ok{background:#e8f5e9;color:#2e7d32}
.badge.in{background:#e8f5e9;color:#1b5e20}
.badge.out{background:#fff3e0;color:#e65100}
input,select{width:100%;padding:9px 11px;border:1px solid #ddd;border-radius:7px;font-size:13px;font-family:inherit;background:#fff;color:#1a1a1a}
input:focus,select:focus{outline:none;border-color:#185FA5}
.frow{display:grid;gap:12px;margin-bottom:12px}
.frow.c2{grid-template-columns:1fr 1fr}
.frow.c3{grid-template-columns:1fr 1fr 1fr}
@media(max-width:600px){.frow.c2,.frow.c3{grid-template-columns:1fr}}
.fg label{font-size:12px;color:#555;display:block;margin-bottom:4px;font-weight:500}
.fg input,.fg select{margin-bottom:0}
.btn{padding:9px 20px;border:1px solid #ddd;border-radius:7px;background:#fff;color:#333;cursor:pointer;font-size:13px;font-family:inherit;font-weight:500}
.btn.primary{background:#185FA5;color:#fff;border-color:#185FA5}
.btn.dng{background:#c62828;color:#fff;border-color:#c62828}
.btn.sm{padding:4px 10px;font-size:12px}
.arow{background:#fff8f8;border-left:3px solid #c62828;border-radius:6px;padding:11px 14px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.aname{font-weight:600;color:#c62828;font-size:13px}
.adetail{font-size:12px;color:#666;margin-top:2px}
.apill{font-size:12px;background:#ffebee;color:#c62828;padding:4px 10px;border-radius:12px;font-weight:500}
.empty{text-align:center;padding:40px;color:#999;font-size:13px}
.loading{text-align:center;padding:32px;color:#888;font-size:13px}
.sbar{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap}
.sbar input,.sbar select{margin-bottom:0;flex:1;min-width:120px}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#185FA5;color:#fff;padding:12px 22px;border-radius:8px;font-size:13px;font-weight:500;z-index:9999;display:none;box-shadow:0 4px 16px rgba(0,0,0,.2);white-space:nowrap}
.toast.ok{background:#2e7d32}.toast.err{background:#c62828}
.ar{display:flex;justify-content:flex-end;gap:8px;margin-top:14px}
.tw{overflow-x:auto}
</style>
</head>
<body>

<div class="topbar">
  <div><div class="title">⚡ Electrical Godown</div><div class="sub">Inventory Management System</div></div>
  <div class="sync" id="syncBar">Connecting...</div>
</div>

<nav class="nav">
  <button class="active" onclick="go('dashboard',this)">Dashboard</button>
  <button onclick="go('items',this)">Items</button>
  <button onclick="go('stockin',this)">Stock IN</button>
  <button onclick="go('stockout',this)">Stock OUT</button>
  <button onclick="go('history',this)">History</button>
  <button onclick="go('alerts',this)" id="alertsTab">Alerts</button>
</nav>

<div class="con">

<!-- DASHBOARD -->
<div id="page-dashboard" class="page active">
  <div class="grid2">
    <div class="metric"><div class="ml">Total Items</div><div class="mv info" id="m-total">—</div></div>
    <div class="metric"><div class="ml">Low Stock</div><div class="mv danger" id="m-low">—</div></div>
    <div class="metric"><div class="ml">Today IN</div><div class="mv success" id="m-in">—</div></div>
    <div class="metric"><div class="ml">Today OUT</div><div class="mv" id="m-out">—</div></div>
  </div>
  <div id="dashAlerts"></div>
  <div class="card"><div class="card-title">Current Stock Overview</div><div class="tw" id="dashTable"><div class="loading">Loading...</div></div></div>
</div>

<!-- ITEMS -->
<div id="page-items" class="page">
  <div class="card">
    <div class="card-title">Add New Item</div>
    <div class="frow c3">
      <div class="fg"><label>Item Name *</label><input id="i-name" placeholder="e.g. MCB 32A Single Pole"/></div>
      <div class="fg"><label>Category</label><select id="i-cat"><option>Wires & Cables</option><option>Switches & Sockets</option><option>MCB & Distribution</option><option>Lights & Fixtures</option><option>Conduits & Fittings</option><option>Fans & Motors</option><option>Tools & Equipment</option><option>Other</option></select></div>
      <div class="fg"><label>Unit</label><select id="i-unit"><option>Pieces</option><option>Meters</option><option>Rolls</option><option>Boxes</option><option>Sets</option><option>Kg</option><option>Coils</option></select></div>
    </div>
    <div class="frow c3">
      <div class="fg"><label>Opening Stock</label><input type="number" id="i-stock" value="0" min="0"/></div>
      <div class="fg"><label>Min Stock (Alert Level)</label><input type="number" id="i-min" value="10" min="0"/></div>
      <div class="fg"><label>Price per Unit (₹)</label><input type="number" id="i-price" value="0" min="0"/></div>
    </div>
    <div class="ar"><button class="btn primary" onclick="addItem()">+ Add Item</button></div>
  </div>
  <div class="card">
    <div class="card-title">All Items</div>
    <div class="sbar"><input id="itemSearch" placeholder="Search items..." oninput="renderItems()"/></div>
    <div class="tw" id="itemsTable"><div class="loading">Loading...</div></div>
  </div>
</div>

<!-- STOCK IN -->
<div id="page-stockin" class="page">
  <div class="card">
    <div class="card-title">Record Stock IN</div>
    <div class="frow c2">
      <div class="fg"><label>Item *</label><select id="si-item"><option value="">-- Select Item --</option></select></div>
      <div class="fg"><label>Quantity *</label><input type="number" id="si-qty" placeholder="Quantity" min="1"/></div>
    </div>
    <div class="frow c2">
      <div class="fg"><label>Supplier Name</label><input id="si-sup" placeholder="Supplier / Vendor name"/></div>
      <div class="fg"><label>Date</label><input type="date" id="si-date"/></div>
    </div>
    <div class="frow"><div class="fg"><label>Note</label><input id="si-note" placeholder="Invoice no. or remarks"/></div></div>
    <div class="ar"><button class="btn primary" onclick="addStockIn()">+ Add Stock IN</button></div>
  </div>
  <div class="card"><div class="card-title">Recent Stock IN</div><div class="tw" id="siTable"><div class="loading">Loading...</div></div></div>
</div>

<!-- STOCK OUT -->
<div id="page-stockout" class="page">
  <div class="card">
    <div class="card-title">Record Stock OUT</div>
    <div class="frow c2">
      <div class="fg"><label>Item *</label><select id="so-item"><option value="">-- Select Item --</option></select></div>
      <div class="fg"><label>Quantity *</label><input type="number" id="so-qty" placeholder="Quantity" min="1"/></div>
    </div>
    <div class="frow c2">
      <div class="fg"><label>Customer / Purpose</label><input id="so-cust" placeholder="Customer name or purpose"/></div>
      <div class="fg"><label>Date</label><input type="date" id="so-date"/></div>
    </div>
    <div class="frow"><div class="fg"><label>Note</label><input id="so-note" placeholder="Bill no. or remarks"/></div></div>
    <div class="ar"><button class="btn primary" onclick="addStockOut()">+ Record Stock OUT</button></div>
  </div>
  <div class="card"><div class="card-title">Recent Stock OUT</div><div class="tw" id="soTable"><div class="loading">Loading...</div></div></div>
</div>

<!-- HISTORY -->
<div id="page-history" class="page">
  <div class="card">
    <div class="card-title">Transaction History</div>
    <div class="sbar">
      <select id="h-item" onchange="renderHistory()"><option value="">All Items</option></select>
      <select id="h-type" onchange="renderHistory()"><option value="">All Types</option><option value="IN">IN</option><option value="OUT">OUT</option></select>
      <input type="date" id="h-date" onchange="renderHistory()" style="max-width:160px;flex:none"/>
      <button class="btn sm" onclick="clearHF()">Clear</button>
    </div>
    <div class="tw" id="histTable"><div class="loading">Loading...</div></div>
  </div>
</div>

<!-- ALERTS -->
<div id="page-alerts" class="page">
  <div class="card">
    <div class="card-title">Low Stock Alerts</div>
    <p style="font-size:13px;color:#666;margin-bottom:14px">Items below minimum level — reorder immediately</p>
    <div id="alertsContent"><div class="loading">Loading...</div></div>
  </div>
</div>

</div>
<div class="toast" id="toast"></div>

<script>
const URL = 'https://ibawonlchzxmocoxkirz.supabase.co';
const KEY = 'sb_publishable_j3BvHCejXy9hOnlB0EpcSw_6nJM5N-l';

const H = { 'apikey': KEY, 'Authorization': 'Bearer ' + KEY, 'Content-Type': 'application/json', 'Prefer': 'return=representation' };

async function api(method, path, body) {
  const opts = { method, headers: H };
  if (body) opts.body = JSON.stringify(body);
  const r = await fetch(URL + '/rest/v1/' + path, opts);
  const txt = await r.text();
  if (!r.ok) throw new Error(txt);
  return txt ? JSON.parse(txt) : [];
}

let items = [], txns = [];
const today = () => new Date().toISOString().split('T')[0];

function toast(msg, type='ok') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast ' + type; t.style.display = 'block';
  setTimeout(() => t.style.display = 'none', 3000);
}
function sync(msg) { document.getElementById('syncBar').textContent = msg; }

async function load() {
  sync('Syncing...');
  try {
    items = await api('GET', 'items?select=*&order=name');
    txns = await api('GET', 'transactions?select=*&order=created_at.desc');
    sync('Synced ' + new Date().toLocaleTimeString());
    renderAll();
  } catch(e) {
    sync('Error');
    toast('Connection error: ' + e.message, 'err');
  }
}

function stock(id) {
  const item = items.find(i => i.id === id);
  let s = item ? (item.opening_stock || 0) : 0;
  txns.forEach(t => { if (t.item_id === id) s += t.type === 'IN' ? t.qty : -t.qty; });
  return Math.max(0, s);
}

function renderAll() {
  renderDash(); renderItems(); renderSI(); renderSO(); renderHistory(); renderAlerts(); fillSelects(); alertBadge();
}

function renderDash() {
  const td = today();
  const tIn = txns.filter(t => t.type==='IN' && t.date===td).reduce((s,t)=>s+t.qty,0);
  const tOut = txns.filter(t => t.type==='OUT' && t.date===td).reduce((s,t)=>s+t.qty,0);
  const low = items.filter(i => stock(i.id) <= i.min_stock && i.min_stock > 0);
  document.getElementById('m-total').textContent = items.length;
  document.getElementById('m-low').textContent = low.length;
  document.getElementById('m-in').textContent = tIn;
  document.getElementById('m-out').textContent = tOut;

  const da = document.getElementById('dashAlerts');
  da.innerHTML = low.length ? '<div class="card" style="border-left:4px solid #c62828"><div class="card-title" style="color:#c62828">⚠ Low Stock ('+low.length+')</div>' +
    low.map(i=>`<div class="arow"><div><div class="aname">${i.name}</div><div class="adetail">${i.category}</div></div><div class="apill">Stock: ${stock(i.id)} | Min: ${i.min_stock}</div></div>`).join('')+'</div>' : '';

  const el = document.getElementById('dashTable');
  if (!items.length) { el.innerHTML='<div class="empty">No items yet. Add from Items tab.</div>'; return; }
  el.innerHTML = '<table><thead><tr><th>Item</th><th>Category</th><th>Stock</th><th>Unit</th><th>Min</th><th>Status</th></tr></thead><tbody>' +
    items.map(i => { const s=stock(i.id), low=s<=i.min_stock&&i.min_stock>0;
      return `<tr><td style="font-weight:500">${i.name}</td><td style="color:#666">${i.category}</td><td style="font-weight:700;${low?'color:#c62828':''}">${s}</td><td>${i.unit}</td><td>${i.min_stock}</td><td><span class="badge ${low?'low':'ok'}">${low?'Low':'OK'}</span></td></tr>`;
    }).join('') + '</tbody></table>';
}

function renderItems() {
  const el = document.getElementById('itemsTable');
  const q = (document.getElementById('itemSearch')?.value||'').toLowerCase();
  const list = items.filter(i => i.name.toLowerCase().includes(q)||(i.category||'').toLowerCase().includes(q));
  if (!list.length) { el.innerHTML='<div class="empty">No items found.</div>'; return; }
  el.innerHTML = '<table><thead><tr><th>Name</th><th>Category</th><th>Stock</th><th>Min</th><th>Unit</th><th>Price</th><th></th></tr></thead><tbody>' +
    list.map(i => { const s=stock(i.id), low=s<=i.min_stock&&i.min_stock>0;
      return `<tr><td style="font-weight:500">${i.name}</td><td>${i.category}</td><td style="font-weight:700;${low?'color:#c62828':''}">${s}</td><td>${i.min_stock}</td><td>${i.unit}</td><td>₹${i.price||0}</td><td><button class="btn sm dng" onclick="delItem('${i.id}')">Del</button></td></tr>`;
    }).join('') + '</tbody></table>';
}

function renderSI() {
  const el = document.getElementById('siTable');
  const list = txns.filter(t=>t.type==='IN').slice(0,30);
  if (!list.length) { el.innerHTML='<div class="empty">No records yet.</div>'; return; }
  el.innerHTML = '<table><thead><tr><th>Date</th><th>Item</th><th>Qty</th><th>Supplier</th><th>Note</th></tr></thead><tbody>' +
    list.map(t => { const it=items.find(i=>i.id===t.item_id);
      return `<tr><td>${t.date}</td><td>${it?it.name:'?'}</td><td style="color:#2e7d32;font-weight:700">+${t.qty} ${it?it.unit:''}</td><td>${t.supplier||'—'}</td><td>${t.note||'—'}</td></tr>`;
    }).join('') + '</tbody></table>';
}

function renderSO() {
  const el = document.getElementById('soTable');
  const list = txns.filter(t=>t.type==='OUT').slice(0,30);
  if (!list.length) { el.innerHTML='<div class="empty">No records yet.</div>'; return; }
  el.innerHTML = '<table><thead><tr><th>Date</th><th>Item</th><th>Qty</th><th>Customer</th><th>Note</th></tr></thead><tbody>' +
    list.map(t => { const it=items.find(i=>i.id===t.item_id);
      return `<tr><td>${t.date}</td><td>${it?it.name:'?'}</td><td style="color:#e65100;font-weight:700">-${t.qty} ${it?it.unit:''}</td><td>${t.customer||'—'}</td><td>${t.note||'—'}</td></tr>`;
    }).join('') + '</tbody></table>';
}

function renderHistory() {
  const el = document.getElementById('histTable');
  const iF=document.getElementById('h-item')?.value||'', tF=document.getElementById('h-type')?.value||'', dF=document.getElementById('h-date')?.value||'';
  let list=[...txns];
  if(iF) list=list.filter(t=>t.item_id===iF);
  if(tF) list=list.filter(t=>t.type===tF);
  if(dF) list=list.filter(t=>t.date===dF);
  if(!list.length){el.innerHTML='<div class="empty">No transactions match filter.</div>';return;}
  el.innerHTML='<table><thead><tr><th>Date</th><th>Type</th><th>Item</th><th>Qty</th><th>Party</th><th>Note</th></tr></thead><tbody>'+
    list.map(t=>{const it=items.find(i=>i.id===t.item_id), p=t.type==='IN'?(t.supplier||'—'):(t.customer||'—');
      return `<tr><td>${t.date}</td><td><span class="badge ${t.type==='IN'?'in':'out'}">${t.type}</span></td><td>${it?it.name:'?'}</td><td style="font-weight:700;color:${t.type==='IN'?'#2e7d32':'#e65100'}">${t.type==='IN'?'+':'-'}${t.qty} ${it?it.unit:''}</td><td>${p}</td><td>${t.note||'—'}</td></tr>`;
    }).join('')+'</tbody></table>';
}

function renderAlerts() {
  const el = document.getElementById('alertsContent');
  const low = items.filter(i=>stock(i.id)<=i.min_stock&&i.min_stock>0);
  if(!low.length){el.innerHTML='<div style="color:#2e7d32;padding:12px 0;font-size:14px">✓ All items adequately stocked. No alerts.</div>';return;}
  el.innerHTML = low.map(i=>{const s=stock(i.id);
    return `<div class="arow"><div><div class="aname">${i.name}</div><div class="adetail">${i.category} · ${i.unit} · ₹${i.price||0}</div></div><div class="apill">Stock: ${s} | Min: ${i.min_stock} | Need ${i.min_stock-s} more</div></div>`;
  }).join('');
}

function alertBadge() {
  const n=items.filter(i=>stock(i.id)<=i.min_stock&&i.min_stock>0).length;
  document.getElementById('alertsTab').innerHTML='Alerts'+(n>0?` <span class="abadge">${n}</span>`:'');
}

function fillSelects() {
  ['si-item','so-item'].forEach(id=>{
    const el=document.getElementById(id); if(!el)return;
    const v=el.value; el.innerHTML='<option value="">-- Select Item --</option>';
    items.forEach(i=>{const o=document.createElement('option');o.value=i.id;o.textContent=i.name+' ('+i.unit+')';el.appendChild(o);});
    if(v)el.value=v;
  });
  const h=document.getElementById('h-item'); if(!h)return;
  const v=h.value; h.innerHTML='<option value="">All Items</option>';
  items.forEach(i=>{const o=document.createElement('option');o.value=i.id;o.textContent=i.name;h.appendChild(o);});
  if(v)h.value=v;
}

async function addItem() {
  const name=document.getElementById('i-name').value.trim();
  if(!name){toast('Enter item name','err');return;}
  try {
    await api('POST','items',{name,category:document.getElementById('i-cat').value,unit:document.getElementById('i-unit').value,opening_stock:parseFloat(document.getElementById('i-stock').value)||0,min_stock:parseFloat(document.getElementById('i-min').value)||0,price:parseFloat(document.getElementById('i-price').value)||0});
    toast('Item added!');
    document.getElementById('i-name').value='';
    document.getElementById('i-stock').value='0';
    document.getElementById('i-min').value='10';
    document.getElementById('i-price').value='0';
    load();
  } catch(e){toast('Error: '+e.message,'err');}
}

async function delItem(id) {
  if(!confirm('Delete this item?'))return;
  try{await api('DELETE','items?id=eq.'+id);toast('Deleted');load();}catch(e){toast('Error: '+e.message,'err');}
}

async function addStockIn() {
  const itemId=document.getElementById('si-item').value, qty=parseFloat(document.getElementById('si-qty').value);
  if(!itemId){toast('Select item','err');return;}
  if(!qty||qty<=0){toast('Enter valid quantity','err');return;}
  try{
    await api('POST','transactions',{item_id:itemId,type:'IN',qty,supplier:document.getElementById('si-sup').value.trim(),date:document.getElementById('si-date').value||today(),note:document.getElementById('si-note').value.trim()});
    toast('Stock IN saved!');
    document.getElementById('si-item').value='';
    document.getElementById('si-qty').value='';
    document.getElementById('si-sup').value='';
    document.getElementById('si-note').value='';
    load();
  }catch(e){toast('Error: '+e.message,'err');}
}

async function addStockOut() {
  const itemId=document.getElementById('so-item').value, qty=parseFloat(document.getElementById('so-qty').value);
  if(!itemId){toast('Select item','err');return;}
  if(!qty||qty<=0){toast('Enter valid quantity','err');return;}
  const cur=stock(itemId);
  if(qty>cur){toast('Not enough stock! Available: '+cur,'err');return;}
  try{
    await api('POST','transactions',{item_id:itemId,type:'OUT',qty,customer:document.getElementById('so-cust').value.trim(),date:document.getElementById('so-date').value||today(),note:document.getElementById('so-note').value.trim()});
    toast('Stock OUT saved!');
    document.getElementById('so-item').value='';
    document.getElementById('so-qty').value='';
    document.getElementById('so-cust').value='';
    document.getElementById('so-note').value='';
    load();
  }catch(e){toast('Error: '+e.message,'err');}
}

function clearHF(){document.getElementById('h-item').value='';document.getElementById('h-type').value='';document.getElementById('h-date').value='';renderHistory();}

function go(name,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav button').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  btn.classList.add('active');
}

document.getElementById('si-date').value=today();
document.getElementById('so-date').value=today();
load();
setInterval(load,30000);
</script>
</body>
</html>
